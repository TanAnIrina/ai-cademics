# ---- Backend (prefix AICADEMICS_) ----
# Where the SQLite database lives.
AICADEMICS_DATABASE_URL=sqlite:///./aicademics.db
# Compressed phase delay (seconds) — keep small for demos, raise for realism.
AICADEMICS_SIM_PHASE_SECONDS=0.4
# How many empty demo classrooms to create on first startup.
AICADEMICS_SEED_CLASSROOMS=3
# Comma-separated list of origins permitted by CORS.
AICADEMICS_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
# Defaults a teacher sees when configuring a room.
AICADEMICS_DEFAULT_SPRINT_MINUTES=20
AICADEMICS_DEFAULT_BREAK_MINUTES=10
AICADEMICS_DEFAULT_NUM_SPRINTS=2
# Turns of off-topic small talk during a break phase.
AICADEMICS_BREAK_TURNS=4
